# Example .env configuration for netdev_backup
# Copy this file to /usr/local/etc/netdev_backup/netdev_backup.env and adjust the values

# Required directories
BACKUP_DIR=/var/backups/netdev
GIT_REPO_DIR=/var/git/netdev_backups
LOG_FILE=/var/log/netdev_backup.log

# Required device file
DEVICES_FILE=/usr/local/etc/netdev_backup/devices.json

# Email settings (optional - leave empty if email is not needed)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=user@example.com
SMTP_PASS=password
EMAIL_FROM=backup@example.com
EMAIL_TO=admin@example.com,support@example.com

# SSH and processing settings
SSH_TIMEOUT=15
MAX_WORKERS=4
RETRY_COUNT=2

# false automatically accepts new host keys; true requires known_hosts to be pre-populated
STRICT_HOST_KEY_CHECKING=false
