# Exemplo de configuração .env para netdev_backup
# Copie este arquivo para /usr/local/etc/netdev_backup/netdev_backup.env e ajuste os valores

# Diretórios obrigatórios
BACKUP_DIR=/var/backups/netdev
GIT_REPO_DIR=/var/git/netdev_backups
LOG_FILE=/var/log/netdev_backup.log

# Arquivo de dispositivos obrigatório
DEVICES_FILE=/usr/local/etc/netdev_backup/devices.json

# Configurações de email (opcionais - deixe vazio se não quiser email)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=usuario@exemplo.com
SMTP_PASS=senha
EMAIL_FROM=backup@exemplo.com
EMAIL_TO=admin@exemplo.com,suporte@exemplo.com

# Configurações de SSH e processamento
SSH_TIMEOUT=15
MAX_WORKERS=4
RETRY_COUNT=2

# false aceita automaticamente host keys novas; true exige known_hosts previamente populado
STRICT_HOST_KEY_CHECKING=false
