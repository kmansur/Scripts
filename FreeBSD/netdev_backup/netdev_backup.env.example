# =====================================================================
# NETDEV BACKUP CONFIGURATION
# =====================================================================
# Environment variables file for the netdev_backup.py script.
# Copy this file to /usr/local/etc/netdev_backup/netdev_backup.env
# and adjust the values for the FreeBSD backup host.
# =====================================================================

# =====================================================================
# SECTION 1: DATABASE CONFIGURATION
# =====================================================================
# The following settings are used to load MikroTik devices from MySQL.
# The script currently uses the same inventory pattern as mikrotik_backup.py:
# table gateway, fields ip/login/senha/descricao, and descricao matching
# PE-* or CE-*.

# Database host/server address.
# Examples: localhost, db.yourdomain.com, 192.168.1.10
DB_HOST=db.yourdomain.com

# Database TCP port.
# Default MySQL/MariaDB port is 3306.
DB_PORT=3306

# Name of the database containing MikroTik inventory records.
DB_NAME=network_inventory

# Database user with read-only access to the inventory table.
DB_USER=netdev_backup

# Password for the database user.
DB_PASS=change_this_password

# =====================================================================
# SECTION 2: DEVICE INVENTORY CONFIGURATION
# =====================================================================
# JSON file containing non-MikroTik devices to back up.
# MikroTik devices are loaded from the database above.
# Each entry should include: ip, vendor, user, password or ssh_key,
# and optionally ssh_passphrase.
#
# Supported JSON vendors in the current script: juniper, extreme
DEVICES_FILE=/usr/local/etc/netdev_backup/devices.json

# =====================================================================
# SECTION 3: DIRECTORIES, LOGGING, AND GIT REPOSITORY
# =====================================================================
# Local directory where backup files will be written.
# The script creates vendor subdirectories under this path.
BACKUP_DIR=/var/backups/netdev

# Git repository directory used for versioning backup files.
# This directory must already be a valid Git repository with a configured
# origin remote. The script commits and pushes on the currently checked-out
# branch.
GIT_REPO_DIR=/var/git/netdev_backups

# Log file path. If this file cannot be opened, the script continues logging
# to stdout only.
LOG_FILE=/var/log/netdev_backup.log

# =====================================================================
# SECTION 4: SSH CONNECTIVITY AND SECURITY
# =====================================================================
# Timeout limit in seconds for SSH connection, authentication, command
# execution, and banner wait operations.
# Recommendation: 10-30 seconds depending on network latency.
SSH_TIMEOUT=15

# Host key policy.
# false: automatically accepts new host keys.
# true: rejects unknown host keys and requires known_hosts to be pre-populated.
# Recommendation for production: true after all devices are registered.
STRICT_HOST_KEY_CHECKING=false

# =====================================================================
# SECTION 5: PERFORMANCE AND RETRIES
# =====================================================================
# Maximum number of devices processed in parallel.
# Higher values finish faster but increase CPU, memory, SSH, and device load.
# Recommendation: start with 4 and tune after observing production behavior.
MAX_WORKERS=4

# Number of retry attempts after the initial attempt.
# Value 2 means up to 3 total attempts per device.
RETRY_COUNT=2

# =====================================================================
# SECTION 6: EMAIL NOTIFICATION CONFIGURATION
# =====================================================================
# SMTP parameters used only when the script is executed with --email and at
# least one failure occurs. Leave SMTP_HOST, EMAIL_FROM, or EMAIL_TO empty to
# disable email delivery.

# SMTP server address.
# Examples: smtp.gmail.com, smtp.yourdomain.com, smtp.office365.com
SMTP_HOST=smtp.example.com

# SMTP server port.
# Common ports: 25 without TLS, 587 with STARTTLS, 465 for implicit TLS
# if supported by your mail environment.
SMTP_PORT=587

# Whether to issue STARTTLS before authentication/sending.
# Accepted true values: 1, true, yes, on
SMTP_STARTTLS=true

# SMTP authentication credentials.
# Leave both empty if the SMTP server does not require authentication.
SMTP_USER=user@example.com
SMTP_PASS=password

# Sender address used in the From header.
EMAIL_FROM=backup@example.com

# Recipient email address(es). Use comma-separated values without spaces.
# Example: admin@example.com,noc@example.com,network@example.com
EMAIL_TO=admin@example.com,support@example.com
