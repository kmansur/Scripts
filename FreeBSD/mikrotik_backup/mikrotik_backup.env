# =====================================================================
# MIKROTIK BACKUP CONFIGURATION
# =====================================================================
# Environment variables file for the mikrotik_backup.py script
# This file contains all credentials and parameters required
# to execute automated backup of MikroTik device configurations
# =====================================================================

# =====================================================================
# SECTION 1: DATABASE CONFIGURATION
# =====================================================================
# The following settings are used to connect to the database
# that stores information about MikroTik devices and backup history

# Database host/server address
# Examples: localhost, db.yourdomain.com, 192.168.1.10
DB_HOST=db.dominio.com.br

# Name of the database to be used
# It is recommended to create a database specifically for MikroTik backups
DB_NAME=db_name

# Database user with read and write permissions
# Important: use a user with minimal necessary privileges
DB_USER=user_mikrotik_bkp

# Password for the database user
# Recommendation: use strong passwords and change periodically
DB_PASS=user_mikrotik_bkp_password

# =====================================================================
# SECTION 2: SSH CONNECTIVITY CONFIGURATION
# =====================================================================
# Parameters related to connectivity testing and SSH connection

# IP address/host for network connectivity testing
# Used by the script to verify if the network is available
# Can be a gateway, DNS server, or any accessible host
SSH_TEST_IP=xxx.xxx.xxx.xxx

# =====================================================================
# SECTION 3: DIRECTORIES AND GIT REPOSITORY CONFIGURATION
# =====================================================================
# Backup storage path and Git integration settings

# Local directory where backup files will be stored
# Ensure sufficient disk space is available
# Recommendation: use a dedicated mount point with separate disk storage
BACKUP_DIR=/usr/local/backups/mikrotik-config

# Git repository directory for backup versioning
# Can be equal to BACKUP_DIR or a specific directory
# The script uses Git to maintain configuration history
GIT_REPO_DIR=/usr/local/backups/mikrotik-config

# Git repository branch where backups will be committed
# Default: main (for recent Git versions)
# Alternatives: master, production, develop, etc.
GIT_BRANCH=main

# =====================================================================
# SECTION 4: TIMEOUT AND PERFORMANCE CONFIGURATION
# =====================================================================
# Parameters related to script execution and performance

# Timeout limit (in seconds) for SSH connections
# Too low a timeout may cause failures on slow connections
# Recommendation: 10-30 seconds depending on network latency
SSH_TIMEOUT=10

# Maximum number of workers/parallel processes to execute backups
# Higher values increase performance but consume more resources
# Recommendation: consider the number of CPUs available on the server
# Example: 4 CPUs = MAX_WORKERS=4-8
MAX_WORKERS=10

# Maximum number of reconnection attempts in case of failure
# Value 2 means: 1 initial attempt + 2 retry attempts = 3 total attempts
# Increase this value for unstable networks
RETRY_COUNT=2

# =====================================================================
# SECTION 5: EMAIL NOTIFICATION CONFIGURATION
# =====================================================================
# SMTP parameters for sending backup reports via email

# SMTP server address for sending emails
# Examples: smtp.gmail.com, smtp.yourdomain.com, smtp.office365.com
SMTP_HOST=smtp.dominio.com.br

# SMTP server port
# Common ports: 25 (no authentication), 587 (TLS), 465 (SSL)
SMTP_PORT=587

# Username for SMTP server authentication
# Usually a complete email address
SMTP_USER=mikrotik_backup@dominio.com.br

# SMTP user password
# Recommendation: use app-specific passwords from providers that support them (Gmail, Office365)
SMTP_PASS=email_password

# Email address of the sender
# Will be displayed as "From:" in sent emails
EMAIL_FROM=mikrotik_backup@dominio.com.br

# Recipient email address(es)
# Multiple emails should be separated by comma (no spaces)
# Example: admin@company.com,ti@company.com,manager@company.com
EMAIL_TO=email1@dominio.com.br,email2@dominio.com.br,email3@dominio.com.br            